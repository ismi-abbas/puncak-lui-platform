---
interface Props {
	title?: string;
	description?: string;
	lang?: string;
	alternateLinks?: Array<{
		href: string;
		lang: string;
	}>;
}

const {
	title = 'Panorama D\'Puncak Lui',
	description = 'A healing destination in Hulu Langat, Selangor.',
	lang = 'en',
	alternateLinks = [],
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		{alternateLinks.map((link) => <link rel="alternate" hreflang={link.lang} href={link.href} />)}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Afacad:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@10..48,500;10..48,650;10..48,700;10..48,800&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
