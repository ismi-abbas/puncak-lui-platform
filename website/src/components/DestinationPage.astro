const localeInfo = {
	ms: {
		htmlLang: 'ms',
		title: 'Panorama Puncak Lui | Healing Stay di Hulu Langat',
		description:
			'Panorama Puncak Lui ialah destinasi healing di Hulu Langat dengan chalet, pemandangan bukit, kolam, terrace, mini hiking dan kemudahan penginapan.',
	},
	en: {
		htmlLang: 'en',
		title: 'Panorama Puncak Lui | Healing Stay in Hulu Langat',
		description:
			'Panorama Puncak Lui is a healing destination in Hulu Langat with chalets, hill views, a pool, terraces, mini hiking and stay amenities.',
	},
	zh: {
		htmlLang: 'zh-Hans',
		title: 'Panorama Puncak Lui | Hulu Langat 疗愈住宿',
		description:
			'Panorama Puncak Lui 是 Hulu Langat 的山坡疗愈住宿，有木屋、山景、泳池、露台、轻徒步和住宿设施。',
	},
};

const lang = Astro.props.lang ?? 'ms';
const current = copy[lang];
const locale = localeInfo[lang];
const languageLinks = [
	['ms', 'BM', getRelativeLocaleUrl('ms')],
	['en', 'EN', getRelativeLocaleUrl('en')],
	['zh', '中文', getRelativeLocaleUrl('zh')],
] as const;
const alternateLinks = [
	{ href: getRelativeLocaleUrl('ms'), lang: 'ms' },
	{ href: getRelativeLocaleUrl('en'), lang: 'en' },
	{ href: getRelativeLocaleUrl('zh'), lang: 'zh-Hans' },
	{ href: getRelativeLocaleUrl('ms'), lang: 'x-default' },
];
const photos = [
	['/photos/room-kiambang.jpeg', 'Chalet room at Panorama at DPuncakLui'],
	['/photos/wooden-chalet.jpeg', 'Wooden chalet exterior at D Puncak Lui'],
	['/photos/pool.jpeg', 'Pool area at D Puncak Lui'],
	['/photos/cloud-walk.jpeg', 'Morning cloud walk viewpoint at D Puncak Lui'],
];
---

<Layout lang={locale.htmlLang} title={locale.title} description={locale.description} alternateLinks={alternateLinks}>
	<main class="site-shell">
		<nav class="nav" aria-label="Main navigation">
			<a class="brand" href={`${getRelativeLocaleUrl(lang)}#top`} aria-label="Panorama Puncak Lui home">
				<span class="brand-mark" aria-hidden="true">PL</span>
				<span>Panorama Puncak Lui</span>
			</a>
			<div class="nav-links">
				<a href="#stay">{current.nav[0]}</a>
				<a href="#rooms">{current.nav[1]}</a>
				<a href="#amenities">{current.nav[2]}</a>
				<a href="#visit">{current.nav[3]}</a>
			</div>
			<div class="language-switcher" aria-label="Language switcher">
				{languageLinks.map(([code, label, href]) => (
					<a class:list={{ active: code === lang }} href={href} lang={localeInfo[code].htmlLang} aria-current={code === lang ? 'page' : undefined}>
						{label}
					</a>
				))}
			</div>
		</nav>

		<section class="hero" id="top" aria-labelledby="hero-title">
			<div class="hero-media" aria-hidden="true">
				<img src="/photos/booking-main.webp" alt="" />
			</div>
			<div class="hero-content">
				<p class="eyebrow">{current.heroEyebrow}</p>
				<h1 id="hero-title">{current.heroTitle}</h1>
				<p class="hero-copy">{current.heroCopy}</p>
				<div class="hero-actions">
					<a class="button primary" href={bookingUrl}>{current.book}</a>
					<a class="button secondary" href={facebookUrl}>{current.updates}</a>
				</div>
			</div>
			<div class="hero-card" aria-label="Destination highlights">
				<span>{current.heroCardLabel}</span>
				<strong>{current.heroCardTitle}</strong>
				<p>{current.heroCardCopy}</p>
			</div>
		</section>

		<section class="intro" aria-label="Retreat summary">
			<p>{current.intro}</p>
		</section>

		<section class="split" id="stay" aria-labelledby="stay-title">
			<div>
				<p class="eyebrow">{current.stayEyebrow}</p>
				<h2 id="stay-title">{current.stayTitle}</h2>
			</div>
			<div class="feature-grid">
				{current.experiences.map((item) => (
					<article class="feature-card">
						<p>{item[0]}</p>
						<h3>{item[1]}</h3>
						<span>{item[2]}</span>
					</article>
				))}
			</div>
		</section>

		<section class="rooms" id="rooms" aria-labelledby="rooms-title">
			<div class="section-head">
				<p class="eyebrow">{current.roomsEyebrow}</p>
				<h2 id="rooms-title">{current.roomsTitle}</h2>
				<p>{current.roomsNote}</p>
			</div>
			<div class="room-grid">
				{current.rooms.map((room, index) => (
					<article class="room-card">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<h3>{room[0]}</h3>
						<p>{room[1]}</p>
						<strong>{room[2]}</strong>
					</article>
				))}
			</div>
		</section>

		<section class="image-band" aria-label="Real destination photos">
			<img src="/photos/pool.jpeg" alt="Pool at D Puncak Lui" />
			<div class="band-panel">
				<p class="eyebrow">{current.bandEyebrow}</p>
				<h2>{current.bandTitle}</h2>
				<p>{current.bandCopy}</p>
			</div>
		</section>

		<section class="photo-gallery" aria-label="Photo gallery">
			{photos.map(([src, alt]) => <img src={src} alt={alt} loading="lazy" />)}
		</section>

		<section class="amenities" id="amenities" aria-labelledby="amenities-title">
			<div class="section-head">
				<p class="eyebrow">{current.amenityEyebrow}</p>
				<h2 id="amenities-title">{current.amenityTitle}</h2>
			</div>
			<ul class="amenity-list" aria-label="Amenities and services">
				{current.amenities.map((amenity) => <li>{amenity}</li>)}
			</ul>
		</section>

		<section class="visit" id="visit" aria-labelledby="visit-title">
			<div class="visit-copy">
				<p class="eyebrow">{current.visitEyebrow}</p>
				<h2 id="visit-title">{current.visitTitle}</h2>
				<p>{current.visitCopy}</p>
			</div>
			<div class="booking-panel">
				<p>{current.ready}</p>
				<div>
					<a class="button primary" href={bookingUrl}>{current.check}</a>
					<a class="text-link" href={facebookUrl}>{current.message}</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(html) {
		scroll-behavior: smooth;
		background: oklch(94% 0.018 118);
	}

	:global(body) {
		margin: 0;
		color: oklch(20% 0.035 122);
		background:
			linear-gradient(180deg, oklch(94% 0.018 118), oklch(88% 0.035 121) 40%, oklch(22% 0.042 125) 40%);
		font-family: 'Afacad', 'Segoe UI', sans-serif;
	}

	:global(a) {
		color: inherit;
	}

	.site-shell {
		--ink: oklch(20% 0.035 122);
		--leaf: oklch(34% 0.07 139);
		--moss: oklch(48% 0.08 122);
		--cream: oklch(95% 0.025 101);
		--mist: oklch(89% 0.024 132);
		--clay: oklch(57% 0.11 55);
		--space-xs: 0.5rem;
		--space-sm: 0.75rem;
		--space-md: 1rem;
		--space-lg: 1.5rem;
		--space-xl: 2rem;
		--space-2xl: clamp(3rem, 7vw, 6rem);
		min-height: 100vh;
		overflow: hidden;
	}

	.nav {
		position: fixed;
		top: var(--space-md);
		left: 50%;
		z-index: 10;
		display: grid;
		width: min(1120px, calc(100% - 2rem));
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: var(--space-md);
		padding: 0.55rem 0.6rem;
		color: oklch(94% 0.018 118);
		background: color-mix(in oklch, oklch(20% 0.035 122) 88%, transparent);
		border: 1px solid color-mix(in oklch, var(--cream) 20%, transparent);
		border-radius: 999px;
		backdrop-filter: blur(16px);
		transform: translateX(-50%);
	}

	.brand,
	.nav-links,
	.language-switcher {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.brand {
		font-weight: 700;
		text-decoration: none;
		white-space: nowrap;
	}

	.brand-mark {
		display: grid;
		width: 2.25rem;
		height: 2.25rem;
		place-items: center;
		color: var(--ink);
		background: var(--cream);
		border-radius: 999px;
		font-family: 'Bricolage Grotesque', 'Trebuchet MS', sans-serif;
		font-size: 0.82rem;
	}

	.nav-links {
		justify-content: center;
	}

	.nav-links a,
	.language-switcher a {
		border-radius: 999px;
		color: color-mix(in oklch, var(--cream) 82%, transparent);
		background: transparent;
		font-size: 0.92rem;
		font-weight: 750;
		text-decoration: none;
		transition: background 180ms ease, color 180ms ease;
	}

	.nav-links a {
		padding: 0.55rem 0.7rem;
	}

	.language-switcher {
		gap: 0.15rem;
		padding: 0.2rem;
		background: color-mix(in oklch, var(--cream) 10%, transparent);
		border-radius: 999px;
	}

	.language-switcher a {
		padding: 0.4rem 0.55rem;
	}

	.nav-links a:hover,
	.language-switcher a:hover,
	.language-switcher a.active {
		color: var(--cream);
		background: color-mix(in oklch, var(--cream) 16%, transparent);
	}

	.hero {
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 92vh;
		align-items: end;
		padding: clamp(7rem, 14vw, 11rem) clamp(1rem, 4vw, 4rem) clamp(2rem, 6vw, 4rem);
		color: var(--cream);
	}

	.hero-media {
		position: absolute;
		inset: 0;
		z-index: -2;
		background: var(--leaf);
	}

	.hero-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.96) contrast(1.04);
	}

	.hero::after {
		position: absolute;
		inset: 0;
		z-index: -1;
		content: '';
		background:
			linear-gradient(90deg, rgba(9, 24, 11, 0.9), rgba(9, 24, 11, 0.48) 64%, rgba(9, 24, 11, 0.26)),
			linear-gradient(0deg, rgba(9, 24, 11, 0.8), rgba(9, 24, 11, 0.24) 70%);
	}

	.hero-content {
		display: grid;
		max-width: 790px;
		gap: var(--space-lg);
		animation: rise-in 850ms cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	.eyebrow {
		margin: 0;
		color: var(--clay);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin: 0;
	}

	h1,
	h2,
	h3 {
		font-family: 'Bricolage Grotesque', 'Trebuchet MS', sans-serif;
		letter-spacing: 0;
	}

	h1 {
		max-width: 820px;
		color: oklch(96% 0.018 102);
		font-size: clamp(4rem, 9vw, 7.4rem);
		font-weight: 700;
		line-height: 0.88;
	}

	h2 {
		font-size: clamp(2rem, 4.2vw, 4.2rem);
		line-height: 0.96;
	}

	h3 {
		font-size: clamp(1.45rem, 3vw, 2rem);
		line-height: 1;
	}

	.hero-copy {
		max-width: 590px;
		color: color-mix(in oklch, var(--cream) 86%, transparent);
		font-size: clamp(1.1rem, 2vw, 1.35rem);
		line-height: 1.45;
	}

	.hero-actions,
	.booking-panel div {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		align-items: center;
	}

	.button,
	.text-link {
		display: inline-flex;
		min-height: 3rem;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
